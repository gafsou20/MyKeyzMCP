{
  "name": "mykeyz-mcp",
  "version": "0.1.0",
  "description": "Serveur MCP exposant l'API MyKeyz (CRM immobilier).",
  "type": "module",
  "bin": {
    "mykeyz-mcp": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "dev:http": "tsx watch src/http.ts",
    "start:http": "tsx src/http.ts",
    "build": "tsc",
    "serve": "node dist/http.js",
    "serve:stdio": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jose": "^5.9.6",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
